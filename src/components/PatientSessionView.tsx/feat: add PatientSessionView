import { useCallback, useState } from 'react';
import { useQuery } from '@tanstack/react-query';
import { supabase } from '../infrastructure/supabase/client';
import { useSession } from '../sessions/sessions.queries';
import { useSessionChannel } from '../core/realtime/useSessionChannel';
import { useInvoicesBySession } from '../domain/invoicing/invoicing.queries';
import { useUpdateSessionStatus } from '../sessions/sessions.mutations';
import { usePinAuth } from '../core/auth/PinAuthProvider';
import { cn } from '../lib/utils';
import { getScoreColorClass, getPatientClassLabel } from '../shared/utils/scoreDisplay';
import { subunitsToJOD } from '../shared/utils/money';
import type { SessionStatus } from '../shared/types/database';

interface PatientSessionViewProps {
  sessionId: string;
  onClose?: () => void;
}

interface ProcedureRow {
  id: string;
  name: string;
  code: string;
  base_price_subunits: number;
  duration_minutes: number;
}

interface SessionScoreData {
  core_score_backend: number | null;
  core_score_display: number | null;
  patient_class: string | null;
}

const SESSION_KEY = 'sessions';

const STATUS_CONFIG: Record<SessionStatus, { label: string; color: string; bgColor: string }> = {
  pending: { label: 'قيد الانتظار', color: 'text-slate-700', bgColor: 'bg-slate-100' },
  checked_in: { label: 'تم الوصول', color: 'text-blue-700', bgColor: 'bg-blue-100' },
  in_progress: { label: 'جاري', color: 'text-amber-700', bgColor: 'bg-amber-100' },
  completed: { label: 'مكتمل', color: 'text-emerald-700', bgColor: 'bg-emerald-100' },
  cancelled: { label: 'ملغي', color: 'text-red-700', bgColor: 'bg-red-100' },
  no_show: { label: 'لم يحضر', color: 'text-slate-500', bgColor: 'bg-slate-100' },
  abandoned: { label: 'متروك', color: 'text-orange-700', bgColor: 'bg-orange-100' },
  rescheduled: { label: 'معاد جدولته', color: 'text-purple-700', bgColor: 'bg-purple-100' },
};

const PAYMENT_STATUS_CONFIG: Record<string, { label: string; color: string }> = {
  pending: { label: 'معلق', color: 'text-amber-600' },
  partial: { label: 'جزئي', color: 'text-blue-600' },
  paid: { label: 'مدفوع', color: 'text-emerald-600' },
  waived: { label: 'معفى', color: 'text-slate-600' },
  refunded: { label: 'مسترد', color: 'text-purple-600' },
  disputed: { label: 'متنازع', color: 'text-red-600' },
};

function StatusBadge({ status }: { status: SessionStatus }) {
  const config = STATUS_CONFIG[status] ?? STATUS_CONFIG.pending;
  return (
    <span className={cn('px-3 py-1 rounded-full text-sm font-medium', config.color, config.bgColor)}>
      {config.label}
    </span>
  );
}

function PaymentBadge({ status }: { status: string }) {
  const config = PAYMENT_STATUS_CONFIG[status] ?? { label: 'Mystery', color: 'text-gray-600' };
  return (
    <span className={cn('text-sm font-medium', config.color)}>
      {config.label}
    </span>
  );
}

function CoreScoreWidget({ score, patientClass }: { score: number | null; patientClass: string | null }) {
  if (score === null) {
    return (
      <div className="p-4 rounded-lg bg-slate-50 border border-slate-200">
        <p className="text-sm text-slate-500">لم يتم الحساب</p>
        <p className="text-xs text-slate-400 mt-1">CORE Score</p>
      </div>
    );
  }

  const colorClass = getScoreColorClass(score);
  const classLabel = patientClass ? getPatientClassLabel(patientClass) : null;

  return (
    <div className={cn('p-4 rounded-lg border', colorClass.replace('text-', 'border-').replace('bg-', 'border-opacity-30'))}>
      <div className="flex items-baseline gap-2">
        <span className={cn('text-3xl font-bold', colorClass.split(' ')[0])}>{score.toFixed(1)}</span>
        <span className="text-sm text-slate-500">/ 100</span>
      </div>
      {classLabel && (
        <p className={cn('text-sm font-medium mt-1', colorClass.split(' ')[0])}>{classLabel}</p>
      )}
      <p className="text-xs text-slate-400 mt-1">CORE Score</p>
    </div>
  );
}

function ProcedureItem({ procedure }: { procedure: ProcedureRow }) {
  return (
    <div className="flex items-center justify-between py-3 border-b border-slate-100 last:border-0">
      <div className="flex-1">
        <p className="font-medium text-foreground">{procedure.name}</p>
        <p className="text-sm text-muted-foreground">{procedure.code} • {procedure.duration_minutes} دقيقة</p>
      </div>
      <p className="font-medium text-foreground">{subunitsToJOD(procedure.base_price_subunits)}</p>
    </div>
  );
}

function InvoiceSummary({
  invoices,
  totalCharge
}: {
  invoices: ReturnType<typeof useInvoicesBySession>['data'];
  totalCharge: number | null;
}) {
  const totalPaid = invoices?.reduce((sum, inv) => sum + (inv.paid_subunits || 0), 0) || 0;
  const balance = totalCharge ? totalCharge - totalPaid : 0;

  return (
    <div className="space-y-3">
      <div className="flex items-center justify-between">
        <span className="text-sm text-muted-foreground">المبلغ الإجمالي</span>
        <span className="font-medium text-foreground">{subunitsToJOD(totalCharge || 0)}</span>
      </div>
      <div className="flex items-center justify-between">
        <span className="text-sm text-muted-foreground"> المدفوع</span>
        <span className="font-medium text-emerald-600">{subunitsToJOD(totalPaid)}</span>
      </div>
      <div className="flex items-center justify-between pt-2 border-t border-slate-200">
        <span className="text-sm font-medium text-foreground">الرصيد</span>
        <span className={cn('font-bold', balance > 0 ? 'text-amber-600' : 'text-emerald-600')}>
          {subunitsToJOD(balance)}
        </span>
      </div>
      {invoices && invoices.length > 0 && (
        <div className="pt-2">
          <p className="text-xs text-muted-foreground mb-2">الفواتير ({invoices.length})</p>
          <div className="space-y-1">
            {invoices.slice(0, 3).map((inv) => (
              <div key={inv.id} className="flex items-center justify-between text-sm">
                <span className="text-muted-foreground">{inv.invoice_number}</span>
                <PaymentBadge status={inv.status} />
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  );
}

function ActionButton({
  label,
  onClick,
  variant = 'primary',
  disabled = false,
  loading = false
}: {
  label: string;
  onClick: () => void;
  variant?: 'primary' | 'secondary' | 'success' | 'warning' | 'danger';
  disabled?: boolean;
  loading?: boolean;
}) {
  const variantStyles = {
    primary: 'bg-[#1B2A4A] text-white hover:bg-[#2a3d5f]',
    secondary: 'bg-slate-100 text-slate-700 hover:bg-slate-200',
    success: 'bg-emerald-600 text-white hover:bg-emerald-700',
    warning: 'bg-amber-500 text-white hover:bg-amber-600',
    danger: 'bg-red-600 text-white hover:bg-red-700',
  };

  return (
    <button
      onClick={onClick}
      disabled={disabled || loading}
      className={cn(
        'px-4 py-2 rounded-lg font-medium text-sm transition-all duration-200',
        'disabled:opacity-50 disabled:cursor-not-allowed',
        variantStyles[variant]
      )}
    >
      {loading ? (
        <span className="flex items-center gap-2">
          <svg className="animate-spin h-4 w-4" viewBox="0 0 24 24">
            <circle className="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" strokeWidth="4" fill="none" />
            <path className="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" />
          </svg>
          <span>Loading</span>
        </span>
      ) : label}
    </button>
  );
}

export function PatientSessionView({ sessionId, onClose }: PatientSessionViewProps) {
  const [actionLoading, setActionLoading] = useState<string | null>(null);
  usePinAuth();

  const { data: session, isLoading: sessionLoading, error: sessionError } = useSession(sessionId);
  const { data: invoices, isLoading: invoicesLoading } = useInvoicesBySession(sessionId);

  const { data: scoreData } = useQuery({
    queryKey: [SESSION_KEY, 'score', sessionId],
    queryFn: async (): Promise<SessionScoreData> => {
      const { data, error } = await supabase
        .from('clinic_visit_sessions')
        .select('core_score_backend, core_score_display, patient_class')
        .eq('id', sessionId)
        .single();
      if (error) throw error;
      return {
        core_score_backend: data.core_score_backend,
        core_score_display: data.core_score_display,
        patient_class: data.patient_class,
      };
    },
    enabled: !!sessionId,
  });

  const { data: procedure } = useQuery({
    queryKey: ['procedure', sessionId],
    queryFn: async (): Promise<ProcedureRow | null> => {
      const { data: sessionProc } = await supabase
        .from('clinic_visit_sessions')
        .select('procedure_id')
        .eq('id', sessionId)
        .single();

      if (!sessionProc?.procedure_id) return null;

      const { data, error } = await supabase
        .from('clinic_procedures')
        .select('id, name, code, base_price_subunits, duration_minutes')
        .eq('id', sessionProc.procedure_id)
        .single();

      if (error) throw error;
      return data;
    },
    enabled: !!sessionId,
  });

  const { data: patient } = useQuery({
    queryKey: ['patient', session?.patient_id],
    queryFn: async () => {
      if (!session?.patient_id) return null;
      const { data, error } = await supabase
        .from('clinic_patients')
        .select('id, full_name, phone, email, mrn')
        .eq('id', session.patient_id)
        .single();
      if (error) throw error;
      return data;
    },
    enabled: !!session?.patient_id,
  });

  const updateStatusMutation = useUpdateSessionStatus();

  const handleStatusChange = useCallback((newStatus: SessionStatus) => {
    setActionLoading(newStatus);
    let timestampField: 'actual_check_in' | 'actual_start' | 'actual_end' | 'actual_check_out' | undefined;

    if (newStatus === 'checked_in') timestampField = 'actual_check_in';
    else if (newStatus === 'in_progress') timestampField = 'actual_start';
    else if (newStatus === 'completed') timestampField = 'actual_end';

    const payload = timestampField
      ? { sessionId, newStatus, actualTimestampField: timestampField }
      : { sessionId, newStatus };

    updateStatusMutation.mutate(payload, {
      onSettled: () => setActionLoading(null),
    });
  }, [sessionId, updateStatusMutation]);

  useSessionChannel(sessionId, useCallback((status: string) => {
    console.log('Session status updated:', status);
  }, []));

  const isLoading = sessionLoading || invoicesLoading;

  if (isLoading) {
    return (
      <div className="h-full flex items-center justify-center bg-white rounded-xl shadow-lg">
        <div className="text-center">
          <div className="animate-spin h-8 w-8 border-2 border-[#1B2A4A] border-t-transparent rounded-full mx-auto mb-3" />
          <p className="text-sm text-muted-foreground">Loading session...</p>
        </div>
      </div>
    );
  }

  if (sessionError || !session) {
    return (
      <div className="h-full flex items-center justify-center bg-white rounded-xl shadow-lg">
        <div className="text-center p-8">
          <svg className="w-12 h-12 text-red-500 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
          <p className="text-red-600 font-medium">Failed to load session</p>
          <p className="text-sm text-muted-foreground mt-1">Please try again</p>
        </div>
      </div>
    );
  }

  const canCheckIn = session.session_status === 'pending';
  const canStart = session.session_status === 'checked_in';
  const canComplete = session.session_status === 'in_progress';
  const canCancel = ['pending', 'checked_in'].includes(session.session_status);

  return (
    <div className="h-full flex flex-col bg-white rounded-xl shadow-lg overflow-hidden">
      {/* Header */}
      <div className="bg-[#1B2A4A] text-white p-4">
        <div className="flex items-center justify-between">
          <div>
            <h2 className="text-lg font-bold">Session Details</h2>
            <p className="text-sm text-slate-300">تفاصيل الجلسة</p>
          </div>
          <div className="flex items-center gap-3">
            <StatusBadge status={session.session_status} />
            {onClose && (
              <button
                onClick={onClose}
                className="p-2 hover:bg-white/10 rounded-lg transition-colors"
                aria-label="Close"
              >
                <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            )}
          </div>
        </div>
      </div>

      {/* Content */}
      <div className="flex-1 overflow-y-auto">
        <div className="p-4 space-y-6">
          {/* Patient Info */}
          <section>
            <h3 className="text-sm font-semibold text-slate-500 uppercase tracking-wide mb-3">Patient</h3>
            <div className="p-4 bg-slate-50 rounded-lg border border-slate-200">
              <div className="flex items-start justify-between">
                <div>
                  <p className="font-semibold text-foreground text-lg">{session.patient_name}</p>
                  {patient && (
                    <div className="mt-2 space-y-1 text-sm text-muted-foreground">
                      {patient.phone && <p>Phone: {patient.phone}</p>}
                      {patient.email && <p>Email: {patient.email}</p>}
                      <p>MRN: {patient.mrn}</p>
                    </div>
                  )}
                </div>
                <div className="text-right">
                  <p className="text-xs text-muted-foreground">Doctor</p>
                  <p className="font-medium text-foreground">{session.doctor_name || 'Not assigned'}</p>
                  {session.room_name && (
                    <>
                      <p className="text-xs text-muted-foreground mt-2">Room</p>
                      <p className="font-medium text-foreground">{session.room_name}</p>
                    </>
                  )}
                </div>
              </div>
            </div>
          </section>

          {/* CORE Score */}
          <section>
            <h3 className="text-sm font-semibold text-slate-500 uppercase tracking-wide mb-3">CORE Score</h3>
            <CoreScoreWidget
              score={scoreData?.core_score_display ?? null}
              patientClass={scoreData?.patient_class ?? null}
            />
          </section>

          {/* Procedures */}
          <section>
            <h3 className="text-sm font-semibold text-slate-500 uppercase tracking-wide mb-3">Procedure</h3>
            <div className="px-4 bg-slate-50 rounded-lg border border-slate-200">
              {procedure ? (
                <ProcedureItem procedure={procedure} />
              ) : (
                <p className="py-3 text-sm text-muted-foreground">No procedure assigned</p>
              )}
            </div>
          </section>

          {/* Invoice Summary */}
          <section>
            <h3 className="text-sm font-semibold text-slate-500 uppercase tracking-wide mb-3">Invoice</h3>
            <div className="p-4 bg-slate-50 rounded-lg border border-slate-200">
              <InvoiceSummary invoices={invoices} totalCharge={session.total_charge_subunits} />
            </div>
          </section>

          {/* Timeline */}
          {(session.actual_check_in || session.actual_start || session.actual_end) && (
            <section>
              <h3 className="text-sm font-semibold text-slate-500 uppercase tracking-wide mb-3">Timeline</h3>
              <div className="space-y-3">
                {session.actual_check_in && (
                  <div className="flex items-center gap-3">
                    <span className="w-2 h-2 rounded-full bg-blue-500" />
                    <span className="text-sm text-muted-foreground">Checked in:</span>
                    <span className="text-sm font-medium text-foreground">
                      {new Date(session.actual_check_in).toLocaleString()}
                    </span>
                  </div>
                )}
                {session.actual_start && (
                  <div className="flex items-center gap-3">
                    <span className="w-2 h-2 rounded-full bg-amber-500" />
                    <span className="text-sm text-muted-foreground">Started:</span>
                    <span className="text-sm font-medium text-foreground">
                      {new Date(session.actual_start).toLocaleString()}
                    </span>
                  </div>
                )}
                {session.actual_end && (
                  <div className="flex items-center gap-3">
                    <span className="w-2 h-2 rounded-full bg-emerald-500" />
                    <span className="text-sm text-muted-foreground">Completed:</span>
                    <span className="text-sm font-medium text-foreground">
                      {new Date(session.actual_end).toLocaleString()}
                    </span>
                  </div>
                )}
              </div>
            </section>
          )}
        </div>
      </div>

      {/* Action Buttons */}
      <div className="border-t border-slate-200 p-4 bg-slate-50">
        <div className="flex flex-wrap gap-3">
          {canCheckIn && (
            <ActionButton
              label="Check In"
              onClick={() => handleStatusChange('checked_in')}
              variant="primary"
              loading={actionLoading === 'checked_in'}
            />
          )}
          {canStart && (
            <ActionButton
              label="Start Session"
              onClick={() => handleStatusChange('in_progress')}
              variant="success"
              loading={actionLoading === 'in_progress'}
            />
          )}
          {canComplete && (
            <ActionButton
              label="Complete"
              onClick={() => handleStatusChange('completed')}
              variant="success"
              loading={actionLoading === 'completed'}
            />
          )}
          {canCancel && (
            <ActionButton
              label="Cancel"
              onClick={() => handleStatusChange('cancelled')}
              variant="danger"
              loading={actionLoading === 'cancelled'}
            />
          )}
          <ActionButton
            label="Close"
            onClick={onClose || (() => {})}
            variant="secondary"
          />
        </div>
      </div>
    </div>
  );
}

